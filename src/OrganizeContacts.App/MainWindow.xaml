<Window x:Class="OrganizeContacts.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OrganizeContacts.App.ViewModels"
        xmlns:m="clr-namespace:OrganizeContacts.Core.Models;assembly=OrganizeContacts.Core"
        Title="OrganizeContacts"
        Height="720" Width="1180"
        MinHeight="520" MinWidth="900"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource MantleBrush}" Padding="20,14"
                BorderBrush="{StaticResource Surface0Brush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="14" Height="14" Fill="{StaticResource AccentBrush}" Margin="0,0,10,0" />
                    <TextBlock Text="OrganizeContacts"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="v0.1.0"
                               Margin="10,3,0,0"
                               FontSize="11"
                               Foreground="{StaticResource Subtext0Brush}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Import vCard…"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding ImportVCardCommand}"
                            Margin="0,0,10,0" />
                    <Button Content="Rescan"
                            Command="{Binding RescanDuplicatesCommand}"
                            Margin="0,0,10,0" />
                    <Button Content="Clear"
                            Command="{Binding ClearAllCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body: contacts list (left) + duplicates (right) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <!-- Contacts -->
            <Border Grid.Column="0" Padding="14">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Contacts"
                               FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <Border Background="{StaticResource MantleBrush}"
                            BorderBrush="{StaticResource Surface0Brush}" BorderThickness="1"
                            CornerRadius="6">
                        <ListBox ItemsSource="{Binding Contacts}"
                                 SelectedItem="{Binding SelectedContact}"
                                 Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type m:Contact}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Organization}"
                                                   Foreground="{StaticResource Subtext0Brush}"
                                                   FontSize="11" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="3"
                          Background="{StaticResource Surface0Brush}"
                          HorizontalAlignment="Stretch" />

            <!-- Duplicates -->
            <Border Grid.Column="2" Padding="14">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,8">
                        <Run Text="Duplicate groups: " />
                        <Run Text="{Binding Duplicates.Count, Mode=OneWay}"
                             Foreground="{StaticResource AccentBrush}" />
                    </TextBlock>
                    <Border Background="{StaticResource MantleBrush}"
                            BorderBrush="{StaticResource Surface0Brush}" BorderThickness="1"
                            CornerRadius="6">
                        <ListBox ItemsSource="{Binding Duplicates}"
                                 SelectedItem="{Binding SelectedDuplicateGroup}"
                                 Background="Transparent" BorderThickness="0"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type m:DuplicateGroup}">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right"
                                                       Foreground="{StaticResource Subtext0Brush}"
                                                       FontSize="11">
                                                <Run Text="× " />
                                                <Run Text="{Binding Count, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Text="{Binding MatchReason}"
                                                       Foreground="{StaticResource AccentAltBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12" />
                                        </DockPanel>
                                        <ItemsControl ItemsSource="{Binding Members}" Margin="8,4,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type m:Contact}">
                                                    <TextBlock Foreground="{StaticResource Subtext1Brush}"
                                                               FontSize="12">
                                                        <Run Text="• " />
                                                        <Run Text="{Binding DisplayName}" />
                                                        <Run Text="  " />
                                                        <Run Text="{Binding Organization}"
                                                             Foreground="{StaticResource Overlay0}" />
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{StaticResource MantleBrush}"
                BorderBrush="{StaticResource Surface0Brush}" BorderThickness="0,1,0,0"
                Padding="14,6">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource Subtext0Brush}"
                       FontSize="12" />
        </Border>
    </Grid>
</Window>
