<Window x:Class="OrganizeContacts.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OrganizeContacts.App.ViewModels"
        xmlns:m="clr-namespace:OrganizeContacts.Core.Models;assembly=OrganizeContacts.Core"
        Title="OrganizeContacts"
        Icon="Assets/OrganizeContacts.ico"
        Height="800" Width="1320"
        MinHeight="620" MinWidth="1040"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding ImportVCardCommand}" />
        <KeyBinding Key="O" Modifiers="Control+Shift" Command="{Binding ImportFolderCommand}" />
        <KeyBinding Key="E" Modifiers="Control" Command="{Binding ExportVCardCommand}" />
        <KeyBinding Key="R" Modifiers="Control" Command="{Binding RescanDuplicatesCommand}" />
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoLastCommand}" />
        <KeyBinding Key="OemComma" Modifiers="Control" Command="{Binding OpenSettingsCommand}" />
    </Window.InputBindings>

    <Grid Background="{DynamicResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource CrustBrush}"
                BorderBrush="{DynamicResource Surface0Brush}"
                BorderThickness="0,0,0,1"
                Padding="20,16,20,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Width="34"
                               Height="34"
                               Source="Assets/OrganizeContacts-64.png"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Margin="0,0,12,0"
                               AutomationProperties.Name="OrganizeContacts logo" />
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="OrganizeContacts"
                                           FontSize="19"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="v0.3.1"
                                           Margin="10,4,0,0"
                                           FontSize="11"
                                           Foreground="{DynamicResource Subtext0Brush}" />
                            </StackPanel>
                            <TextBlock Text="Import, clean, dedupe, and export contacts"
                                       Foreground="{DynamicResource Subtext0Brush}"
                                       FontSize="12"
                                       Margin="0,3,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <WrapPanel Grid.Row="1"
                           Margin="0,14,0,0"
                           VerticalAlignment="Center">
                    <Border Style="{StaticResource ToolbarGroup}">
                        <StackPanel>
                            <TextBlock Text="IMPORT" Style="{StaticResource ToolbarGroupLabel}" />
                            <WrapPanel>
                                <Button Content="Folder..."
                                        Style="{StaticResource AccentButton}"
                                        Command="{Binding ImportFolderCommand}"
                                        ToolTip="Ctrl+Shift+O - import every supported contact file in a folder"
                                        AutomationProperties.Name="Import a folder of contact files"
                                        Margin="0,0,8,0" />
                                <Button Content="vCard..."
                                        Style="{StaticResource ToolbarButton}"
                                        Command="{Binding ImportVCardCommand}"
                                        ToolTip="Ctrl+O - read a .vcf or .vcard file with preview"
                                        AutomationProperties.Name="Import vCard file" />
                                <Button Content="Google CSV..."
                                        Style="{StaticResource ToolbarButton}"
                                        Command="{Binding ImportGoogleCsvCommand}"
                                        ToolTip="Read a Google Contacts CSV export"
                                        AutomationProperties.Name="Import Google CSV" />
                                <Button Content="Outlook CSV..."
                                        Style="{StaticResource ToolbarButton}"
                                        Command="{Binding ImportOutlookCsvCommand}"
                                        ToolTip="Read an Outlook for Windows CSV export"
                                        AutomationProperties.Name="Import Outlook CSV" />
                                <Button Content="CardDAV..."
                                        Style="{StaticResource ToolbarButton}"
                                        Command="{Binding ImportCardDavCommand}"
                                        ToolTip="Connect to a CardDAV server and import an address book"
                                        AutomationProperties.Name="Connect to CardDAV server" />
                                <Button Content="LDIF..."
                                        Style="{StaticResource ToolbarButton}"
                                        Command="{Binding ImportLdifCommand}"
                                        ToolTip="Read a Thunderbird/Mozilla LDIF export"
                                        AutomationProperties.Name="Import LDIF" />
                                <Button Content="jCard..."
                                        Style="{StaticResource ToolbarButton}"
                                        Command="{Binding ImportJCardCommand}"
                                        ToolTip="Read a jCard (RFC 7095) JSON file"
                                        AutomationProperties.Name="Import jCard" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ToolbarGroup}">
                        <StackPanel>
                            <TextBlock Text="EXPORT" Style="{StaticResource ToolbarGroupLabel}" />
                            <WrapPanel>
                                <Button Content="Export..."
                                        Style="{StaticResource ToolbarButton}"
                                        Command="{Binding ExportVCardCommand}"
                                        ToolTip="Ctrl+E - write the current contacts to a file"
                                        AutomationProperties.Name="Export contacts" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ToolbarGroup}">
                        <StackPanel>
                            <TextBlock Text="TOOLS" Style="{StaticResource ToolbarGroupLabel}" />
                            <WrapPanel>
                                <Button Content="Rescan"
                                        Style="{StaticResource ToolbarButton}"
                                        Command="{Binding RescanDuplicatesCommand}"
                                        ToolTip="Ctrl+R - re-run the duplicate scan"
                                        AutomationProperties.Name="Rescan duplicates" />
                                <Button Content="Cleanup..."
                                        Style="{StaticResource ToolbarButton}"
                                        Command="{Binding RunCleanupCommand}"
                                        ToolTip="Normalize and dedupe fields within each contact"
                                        AutomationProperties.Name="Run batch cleanup" />
                                <Button Content="Auto-merge"
                                        Style="{StaticResource ToolbarButton}"
                                        Command="{Binding AutoMergeCommand}"
                                        ToolTip="Auto-merge groups whose secondaries are subsets of the primary"
                                        AutomationProperties.Name="Auto-merge subset duplicates" />
                                <Button Content="Undo"
                                        Style="{StaticResource ToolbarButton}"
                                        Command="{Binding UndoLastCommand}"
                                        ToolTip="Ctrl+Z - undo the most recent merge"
                                        AutomationProperties.Name="Undo last merge" />
                                <Button Content="History..."
                                        Style="{StaticResource ToolbarButton}"
                                        Command="{Binding OpenRestoreHistoryCommand}"
                                        ToolTip="Review imports and rollback snapshots"
                                        AutomationProperties.Name="Open restore history" />
                                <Button Content="Settings..."
                                        Style="{StaticResource ToolbarButton}"
                                        Command="{Binding OpenSettingsCommand}"
                                        ToolTip="Ctrl+, - region, match profile, canonicalization, theme"
                                        AutomationProperties.Name="Open settings" />
                                <Button Content="Clear visible"
                                        Style="{StaticResource ToolbarButton}"
                                        Command="{Binding ClearAllCommand}"
                                        ToolTip="Soft-delete contacts matching the current search and queue filter"
                                        AutomationProperties.Name="Soft-delete the visible contacts" />
                                <Button Content="Clear all..."
                                        Style="{StaticResource ToolbarButton}"
                                        Command="{Binding ClearAllContactsCommand}"
                                        ToolTip="Soft-delete every imported contact, ignoring search and queue filters"
                                        AutomationProperties.Name="Soft-delete all imported contacts" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource SectionPanel}"
                    Padding="14">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Contacts"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Imported people and source metadata"
                                       Foreground="{DynamicResource Subtext0Brush}"
                                       FontSize="12"
                                       Margin="0,3,0,0" />
                        </StackPanel>
                        <Border Grid.Column="1"
                                Background="{DynamicResource BaseBrush}"
                                BorderBrush="{DynamicResource Surface0Brush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="10,5"
                                VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource PillText}">
                                <Run Text="{Binding Contacts.Count, Mode=OneWay}" />
                                <Run Text=" contacts" />
                            </TextBlock>
                        </Border>
                    </Grid>

                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="200" />
                        </Grid.ColumnDefinitions>

                        <Grid>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.Name="Search contacts"
                                     ToolTip="Search by name, organization, email, phone, notes" />
                            <TextBlock Text="Search contacts, emails, phones..."
                                       Foreground="{DynamicResource Overlay1Brush}"
                                       Margin="12,0,0,0"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchText}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding ReviewQueues}"
                                  SelectedItem="{Binding SelectedQueue}"
                                  AutomationProperties.Name="Review queue filter"
                                  Margin="10,0,0,0" />
                    </Grid>

                    <Grid>
                        <ListBox ItemsSource="{Binding ContactsView}"
                                 SelectedItem="{Binding SelectedContact}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 AutomationProperties.Name="Contacts list">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type m:Contact}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13" />
                                        <TextBlock Foreground="{DynamicResource Subtext0Brush}"
                                                   FontSize="12"
                                                   Margin="0,3,0,0">
                                            <Run Text="{Binding Organization}" />
                                            <Run Text="  -  " />
                                            <Run Text="{Binding SourceFormat}" />
                                        </TextBlock>
                                        <TextBlock Foreground="{DynamicResource Overlay1Brush}"
                                                   FontSize="11"
                                                   Margin="0,3,0,0">
                                            <Run Text="{Binding Emails.Count, Mode=OneWay}" />
                                            <Run Text=" emails  -  " />
                                            <Run Text="{Binding Phones.Count, Mode=OneWay}" />
                                            <Run Text=" phones" />
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Background="{DynamicResource MantleBrush}"
                                IsHitTestVisible="False"
                                Padding="28">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Contacts.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        MaxWidth="360">
                                <TextBlock Text="No contacts imported"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Import one file or choose a folder to preview every supported contact file before anything is committed."
                                           Foreground="{DynamicResource Subtext0Brush}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          Margin="4,0" />

            <Border Grid.Column="2"
                    Style="{StaticResource SectionPanel}"
                    Padding="14">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Duplicate review"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Transparent match signals before merge"
                                       Foreground="{DynamicResource Subtext0Brush}"
                                       FontSize="12"
                                       Margin="0,3,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Background="{DynamicResource BaseBrush}"
                                    BorderBrush="{DynamicResource Surface0Brush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10,5"
                                    Margin="0,0,10,0">
                                <TextBlock Style="{StaticResource PillText}">
                                    <Run Text="{Binding Duplicates.Count, Mode=OneWay}" />
                                    <Run Text=" groups" />
                                </TextBlock>
                            </Border>
                            <Button Content="Review &amp; merge..."
                                    Command="{Binding ReviewMergeCommand}"
                                    Style="{StaticResource AccentButton}"
                                    AutomationProperties.Name="Open merge review for selected group" />
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <ListBox ItemsSource="{Binding Duplicates}"
                                 SelectedItem="{Binding SelectedDuplicateGroup}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 HorizontalContentAlignment="Stretch"
                                 AutomationProperties.Name="Duplicate groups">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type m:DuplicateGroup}">
                                    <StackPanel>
                                        <DockPanel>
                                            <Border DockPanel.Dock="Right"
                                                    Background="{DynamicResource BaseBrush}"
                                                    BorderBrush="{DynamicResource Surface0Brush}"
                                                    BorderThickness="1"
                                                    CornerRadius="11"
                                                    Padding="8,4"
                                                    Margin="10,0,0,0">
                                                <TextBlock Foreground="{DynamicResource Subtext1Brush}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold">
                                                    <Run Text="{Binding Count, Mode=OneWay}" />
                                                    <Run Text=" contacts - " />
                                                    <Run Text="{Binding Confidence, Mode=OneWay, StringFormat={}{0:P0}}"
                                                         Foreground="{DynamicResource AccentAltBrush}" />
                                                </TextBlock>
                                            </Border>
                                            <TextBlock Text="{Binding MatchReason}"
                                                       Foreground="{DynamicResource AccentAltBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13" />
                                        </DockPanel>
                                        <ItemsControl ItemsSource="{Binding Members}" Margin="8,6,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type m:Contact}">
                                                    <TextBlock Foreground="{DynamicResource Subtext1Brush}"
                                                               FontSize="12">
                                                        <Run Text="- " />
                                                        <Run Text="{Binding DisplayName}" />
                                                        <Run Text="  " />
                                                        <Run Text="{Binding Organization}"
                                                             Foreground="{DynamicResource Overlay1Brush}" />
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <ItemsControl ItemsSource="{Binding Signals}" Margin="8,6,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock FontSize="11"
                                                               Foreground="{DynamicResource Overlay1Brush}">
                                                        <Run Text="Signal: " />
                                                        <Run Text="{Binding Label}"
                                                             Foreground="{DynamicResource SuccessBrush}" />
                                                        <Run Text=" +" />
                                                        <Run Text="{Binding Weight, StringFormat={}{0:0.00}}" />
                                                        <Run Text=" - " />
                                                        <Run Text="{Binding Detail}" />
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Background="{DynamicResource MantleBrush}"
                                IsHitTestVisible="False"
                                Padding="28">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Duplicates.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        MaxWidth="380">
                                <TextBlock Text="No duplicate groups"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="After import, rescan runs automatically and shows match reasons, confidence, and merge candidates here."
                                           Foreground="{DynamicResource Subtext0Brush}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource CrustBrush}"
                BorderBrush="{DynamicResource Surface0Brush}"
                BorderThickness="0,1,0,0"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource Subtext0Brush}"
                           FontSize="12"
                           AutomationProperties.LiveSetting="Polite"
                           AutomationProperties.Name="Status message" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,10,0">
                        <StackPanel.Style>
                            <Style TargetType="{x:Type StackPanel}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProgressVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="{Binding ProgressLabel}"
                                   Foreground="{DynamicResource Subtext1Brush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="260"
                                   Margin="0,0,8,0"
                                   AutomationProperties.LiveSetting="Polite" />
                        <ProgressBar Width="210"
                                     Height="8"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="{Binding ProgressValue}"
                                     IsIndeterminate="{Binding IsProgressIndeterminate}"
                                     AutomationProperties.Name="{Binding ProgressLabel}" />
                    </StackPanel>
                    <Border Background="{DynamicResource MantleBrush}"
                            BorderBrush="{DynamicResource Surface0Brush}"
                            BorderThickness="1"
                            CornerRadius="11"
                            Padding="9,4"
                            Margin="0,0,8,0">
                        <Border.Style>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDuplicateScanRunning}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="Scanning duplicates"
                                   Foreground="{DynamicResource AccentAltBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold" />
                    </Border>
                    <Border Background="{DynamicResource MantleBrush}"
                            BorderBrush="{DynamicResource Surface0Brush}"
                            BorderThickness="1"
                            CornerRadius="11"
                            Padding="9,4">
                        <Border.Style>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="Working"
                                   Foreground="{DynamicResource AccentAltBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
