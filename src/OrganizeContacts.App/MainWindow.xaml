<Window x:Class="OrganizeContacts.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OrganizeContacts.App.ViewModels"
        xmlns:m="clr-namespace:OrganizeContacts.Core.Models;assembly=OrganizeContacts.Core"
        Title="OrganizeContacts"
        Height="760" Width="1240"
        MinHeight="560" MinWidth="980"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding ImportVCardCommand}" />
        <KeyBinding Key="E" Modifiers="Control" Command="{Binding ExportVCardCommand}" />
        <KeyBinding Key="R" Modifiers="Control" Command="{Binding RescanDuplicatesCommand}" />
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoLastCommand}" />
        <KeyBinding Key="OemComma" Modifiers="Control" Command="{Binding OpenSettingsCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource MantleBrush}" Padding="20,14"
                BorderBrush="{StaticResource Surface0Brush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="14" Height="14" Fill="{StaticResource AccentBrush}" Margin="0,0,10,0" />
                    <TextBlock Text="OrganizeContacts"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="v0.2.0"
                               Margin="10,3,0,0"
                               FontSize="11"
                               Foreground="{StaticResource Subtext0Brush}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Import vCard…"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding ImportVCardCommand}"
                            ToolTip="Ctrl+O · Read a .vcf file with preview"
                            AutomationProperties.Name="Import vCard file"
                            Margin="0,0,8,0" />
                    <Button Content="Export…"
                            Command="{Binding ExportVCardCommand}"
                            ToolTip="Ctrl+E · Write the current contacts to a .vcf file"
                            AutomationProperties.Name="Export contacts to vCard"
                            Margin="0,0,8,0" />
                    <Button Content="Rescan"
                            Command="{Binding RescanDuplicatesCommand}"
                            ToolTip="Ctrl+R · Re-run the duplicate scan"
                            AutomationProperties.Name="Rescan duplicates"
                            Margin="0,0,8,0" />
                    <Button Content="Undo"
                            Command="{Binding UndoLastCommand}"
                            ToolTip="Ctrl+Z · Undo the most recent merge"
                            AutomationProperties.Name="Undo last merge"
                            Margin="0,0,8,0" />
                    <Button Content="History…"
                            Command="{Binding OpenRestoreHistoryCommand}"
                            ToolTip="Imports + rollback snapshots"
                            AutomationProperties.Name="Open restore history"
                            Margin="0,0,8,0" />
                    <Button Content="Settings…"
                            Command="{Binding OpenSettingsCommand}"
                            ToolTip="Ctrl+, · Region, match profile, canonicalization"
                            AutomationProperties.Name="Open settings"
                            Margin="0,0,8,0" />
                    <Button Content="Clear"
                            Command="{Binding ClearAllCommand}"
                            AutomationProperties.Name="Soft-delete all visible contacts" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <!-- Contacts -->
            <Border Grid.Column="0" Padding="14">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,8">
                        <Run Text="Contacts: " />
                        <Run Text="{Binding Contacts.Count, Mode=OneWay}"
                             Foreground="{StaticResource AccentAltBrush}" />
                    </TextBlock>
                    <Border Background="{StaticResource MantleBrush}"
                            BorderBrush="{StaticResource Surface0Brush}" BorderThickness="1"
                            CornerRadius="6">
                        <ListBox ItemsSource="{Binding Contacts}"
                                 SelectedItem="{Binding SelectedContact}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 AutomationProperties.Name="Contacts list">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type m:Contact}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                        <TextBlock Foreground="{StaticResource Subtext0Brush}"
                                                   FontSize="11">
                                            <Run Text="{Binding Organization}" />
                                            <Run Text="  ·  " />
                                            <Run Text="{Binding SourceFormat}" />
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="3"
                          Background="{StaticResource Surface0Brush}"
                          HorizontalAlignment="Stretch" />

            <!-- Duplicates -->
            <Border Grid.Column="2" Padding="14">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock DockPanel.Dock="Left"
                                   FontSize="14" FontWeight="SemiBold">
                            <Run Text="Duplicate groups: " />
                            <Run Text="{Binding Duplicates.Count, Mode=OneWay}"
                                 Foreground="{StaticResource AccentBrush}" />
                        </TextBlock>
                        <Button DockPanel.Dock="Right"
                                Content="Review &amp; merge…"
                                Command="{Binding ReviewMergeCommand}"
                                Style="{StaticResource AccentButton}"
                                AutomationProperties.Name="Open merge review for selected group" />
                    </DockPanel>
                    <Border Background="{StaticResource MantleBrush}"
                            BorderBrush="{StaticResource Surface0Brush}" BorderThickness="1"
                            CornerRadius="6">
                        <ListBox ItemsSource="{Binding Duplicates}"
                                 SelectedItem="{Binding SelectedDuplicateGroup}"
                                 Background="Transparent" BorderThickness="0"
                                 HorizontalContentAlignment="Stretch"
                                 AutomationProperties.Name="Duplicate groups">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type m:DuplicateGroup}">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right"
                                                       Foreground="{StaticResource Subtext0Brush}"
                                                       FontSize="11">
                                                <Run Text="× " />
                                                <Run Text="{Binding Count, Mode=OneWay}" />
                                                <Run Text="  ·  " />
                                                <Run Text="{Binding Confidence, Mode=OneWay, StringFormat={}{0:P0}}"
                                                     Foreground="{StaticResource AccentAltBrush}" />
                                            </TextBlock>
                                            <TextBlock Text="{Binding MatchReason}"
                                                       Foreground="{StaticResource AccentAltBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12" />
                                        </DockPanel>
                                        <ItemsControl ItemsSource="{Binding Members}" Margin="8,4,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type m:Contact}">
                                                    <TextBlock Foreground="{StaticResource Subtext1Brush}"
                                                               FontSize="12">
                                                        <Run Text="• " />
                                                        <Run Text="{Binding DisplayName}" />
                                                        <Run Text="  " />
                                                        <Run Text="{Binding Organization}"
                                                             Foreground="{StaticResource Overlay0Brush}" />
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <ItemsControl ItemsSource="{Binding Signals}" Margin="8,4,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock FontSize="11"
                                                               Foreground="{StaticResource Overlay0Brush}">
                                                        <Run Text="↳ " />
                                                        <Run Text="{Binding Label}"
                                                             Foreground="{StaticResource SuccessBrush}" />
                                                        <Run Text=" (+" />
                                                        <Run Text="{Binding Weight, StringFormat={}{0:0.00}}" />
                                                        <Run Text=") " />
                                                        <Run Text="{Binding Detail}" />
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{StaticResource MantleBrush}"
                BorderBrush="{StaticResource Surface0Brush}" BorderThickness="0,1,0,0"
                Padding="14,6">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource Subtext0Brush}"
                       FontSize="12"
                       AutomationProperties.LiveSetting="Polite"
                       AutomationProperties.Name="Status message" />
        </Border>
    </Grid>
</Window>
