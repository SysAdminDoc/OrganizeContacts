<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <RootNamespace>OrganizeContacts.App</RootNamespace>
    <AssemblyName>OrganizeContacts</AssemblyName>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>Assets\OrganizeContacts.ico</ApplicationIcon>
    <Version>0.3.2</Version>
    <AssemblyVersion>0.3.2.0</AssemblyVersion>
    <FileVersion>0.3.2.0</FileVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\OrganizeContacts.ico" />
    <Resource Include="Assets\OrganizeContacts-32.png" />
    <Resource Include="Assets\OrganizeContacts-64.png" />
    <Resource Include="Assets\OrganizeContacts-256.png" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\OrganizeContacts.Core\OrganizeContacts.Core.csproj" />
  </ItemGroup>

</Project>
