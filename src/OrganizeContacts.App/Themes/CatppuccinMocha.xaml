<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Catppuccin Mocha palette -->
    <Color x:Key="Base">#1E1E2E</Color>
    <Color x:Key="Mantle">#181825</Color>
    <Color x:Key="Crust">#11111B</Color>
    <Color x:Key="Surface0">#313244</Color>
    <Color x:Key="Surface1">#45475A</Color>
    <Color x:Key="Surface2">#585B70</Color>
    <Color x:Key="Overlay0">#6C7086</Color>
    <Color x:Key="Overlay1">#7F849C</Color>
    <Color x:Key="Subtext0">#A6ADC8</Color>
    <Color x:Key="Subtext1">#BAC2DE</Color>
    <Color x:Key="Text">#CDD6F4</Color>
    <Color x:Key="Lavender">#B4BEFE</Color>
    <Color x:Key="Blue">#89B4FA</Color>
    <Color x:Key="Sapphire">#74C7EC</Color>
    <Color x:Key="Sky">#89DCEB</Color>
    <Color x:Key="Teal">#94E2D5</Color>
    <Color x:Key="Green">#A6E3A1</Color>
    <Color x:Key="Yellow">#F9E2AF</Color>
    <Color x:Key="Peach">#FAB387</Color>
    <Color x:Key="Maroon">#EBA0AC</Color>
    <Color x:Key="Red">#F38BA8</Color>
    <Color x:Key="Mauve">#CBA6F7</Color>
    <Color x:Key="Pink">#F5C2E7</Color>

    <SolidColorBrush x:Key="BaseBrush"      Color="{StaticResource Base}" />
    <SolidColorBrush x:Key="MantleBrush"    Color="{StaticResource Mantle}" />
    <SolidColorBrush x:Key="CrustBrush"     Color="{StaticResource Crust}" />
    <SolidColorBrush x:Key="Surface0Brush" Color="{StaticResource Surface0}" />
    <SolidColorBrush x:Key="Surface1Brush" Color="{StaticResource Surface1}" />
    <SolidColorBrush x:Key="Surface2Brush" Color="{StaticResource Surface2}" />
    <SolidColorBrush x:Key="Overlay0Brush" Color="{StaticResource Overlay0}" />
    <SolidColorBrush x:Key="Overlay1Brush" Color="{StaticResource Overlay1}" />
    <SolidColorBrush x:Key="Subtext0Brush" Color="{StaticResource Subtext0}" />
    <SolidColorBrush x:Key="Subtext1Brush" Color="{StaticResource Subtext1}" />
    <SolidColorBrush x:Key="TextBrush"      Color="{StaticResource Text}" />
    <SolidColorBrush x:Key="AccentBrush"    Color="{StaticResource Mauve}" />
    <SolidColorBrush x:Key="AccentAltBrush" Color="{StaticResource Blue}" />
    <SolidColorBrush x:Key="DangerBrush"    Color="{StaticResource Red}" />
    <SolidColorBrush x:Key="WarningBrush"   Color="{StaticResource Peach}" />
    <SolidColorBrush x:Key="SuccessBrush"   Color="{StaticResource Green}" />

</ResourceDictionary>
