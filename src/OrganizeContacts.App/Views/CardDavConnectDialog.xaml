<Window x:Class="OrganizeContacts.App.Views.CardDavConnectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connect to CardDAV server"
        Height="520" Width="540"
        MinHeight="420" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Connect to CardDAV"
                   FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Grid.Row="1" Foreground="{StaticResource Subtext0Brush}" FontSize="11" Margin="0,0,0,12"
                   TextWrapping="Wrap"
                   Text="Read-only — fetches every card from the chosen address book and runs them through the same preview/snapshot/commit pipeline as a local vCard import. Credentials are stored encrypted via DPAPI." />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Server URL"   Margin="0,4,8,4" Foreground="{StaticResource Subtext0Brush}" />
            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="UrlBox"     Margin="0,4,0,4"
                       AutomationProperties.Name="CardDAV server URL"
                       ToolTip="e.g. https://nextcloud.example.com/remote.php/dav/" />
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Username"     Margin="0,4,8,4" Foreground="{StaticResource Subtext0Brush}" />
            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="UserBox"    Margin="0,4,0,4"
                       AutomationProperties.Name="CardDAV username" />
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Password"     Margin="0,4,8,4" Foreground="{StaticResource Subtext0Brush}" />
            <PasswordBox Grid.Row="2" Grid.Column="1" x:Name="PassBox"  Margin="0,4,0,4"
                         AutomationProperties.Name="CardDAV password" />
            <CheckBox  Grid.Row="3" Grid.Column="1" x:Name="SaveCredsBox"
                       Content="Save credentials in DPAPI vault"
                       IsChecked="True"
                       Foreground="{StaticResource Subtext0Brush}" Margin="0,4,0,4" />
        </Grid>

        <Border Grid.Row="3" Margin="0,12,0,0"
                Background="{StaticResource MantleBrush}"
                BorderBrush="{StaticResource Surface0Brush}"
                BorderThickness="1" CornerRadius="6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           FontWeight="SemiBold" Margin="10,8,10,4"
                           Foreground="{StaticResource Subtext1Brush}">
                    <Run Text="Address books " />
                    <Run Text="(select one to import)"
                         Foreground="{StaticResource Subtext0Brush}" FontSize="11" />
                </TextBlock>
                <ListBox x:Name="BooksList" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Url}"
                                           Foreground="{StaticResource Subtext0Brush}"
                                           FontSize="11" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <DockPanel Grid.Row="4" Margin="0,12,0,0">
            <Button Content="Discover books"
                    DockPanel.Dock="Left"
                    Click="OnDiscover" />
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="Cancel" Click="OnCancel" Margin="0,0,10,0" IsCancel="True" />
                <Button Content="Import selected"
                        Click="OnImport"
                        Style="{StaticResource AccentButton}"
                        IsDefault="True" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
