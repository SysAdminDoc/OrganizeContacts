<Window x:Class="OrganizeContacts.App.Views.CleanupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batch cleanup"
        Height="540" Width="640"
        MinHeight="460" MinWidth="540"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Batch cleanup"
                   FontSize="18" FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" Margin="0,0,0,4"
                           Foreground="{StaticResource Subtext1Brush}"
                           Text="Within each contact" />
                <CheckBox x:Name="DedupePhonesBox"     IsChecked="True" Content="Dedupe phones (canonical: E.164 / last 7 digits)" Margin="0,4,0,0" Foreground="{StaticResource Subtext0Brush}" />
                <CheckBox x:Name="DedupeEmailsBox"     IsChecked="True" Content="Dedupe emails (provider canonicalization)"           Margin="0,4,0,0" Foreground="{StaticResource Subtext0Brush}" />
                <CheckBox x:Name="DedupeUrlsBox"       IsChecked="True" Content="Dedupe URLs"                                          Margin="0,4,0,0" Foreground="{StaticResource Subtext0Brush}" />
                <CheckBox x:Name="DedupeCategoriesBox" IsChecked="True" Content="Dedupe categories"                                    Margin="0,4,0,0" Foreground="{StaticResource Subtext0Brush}" />
                <CheckBox x:Name="NormalizePhonesBox"  IsChecked="True" Content="Normalize phones to E.164 (uses default region)"      Margin="0,4,0,0" Foreground="{StaticResource Subtext0Brush}" />
                <CheckBox x:Name="CanonicalizeEmailsBox" IsChecked="True" Content="Canonicalize emails (provider profiles)"            Margin="0,4,0,0" Foreground="{StaticResource Subtext0Brush}" />

                <TextBlock FontWeight="SemiBold" Margin="0,18,0,4"
                           Foreground="{StaticResource Subtext1Brush}"
                           Text="Optional regex find/replace" />
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Target" Margin="0,4,8,4"
                               Foreground="{StaticResource Subtext0Brush}" />
                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="RegexTargetCombo" Margin="0,4,0,4">
                        <ComboBoxItem Content="(none)" IsSelected="True" />
                        <ComboBoxItem Content="FormattedName" />
                        <ComboBoxItem Content="GivenName" />
                        <ComboBoxItem Content="FamilyName" />
                        <ComboBoxItem Content="Organization" />
                        <ComboBoxItem Content="Title" />
                        <ComboBoxItem Content="Notes" />
                        <ComboBoxItem Content="EmailAddress" />
                        <ComboBoxItem Content="PhoneRaw" />
                    </ComboBox>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Pattern"     Margin="0,4,8,4" Foreground="{StaticResource Subtext0Brush}" />
                    <TextBox   Grid.Row="1" Grid.Column="1" x:Name="RegexPatternBox" Margin="0,4,0,4" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Replacement" Margin="0,4,8,4" Foreground="{StaticResource Subtext0Brush}" />
                    <TextBox   Grid.Row="2" Grid.Column="1" x:Name="RegexReplacementBox" Margin="0,4,0,4" />
                    <CheckBox  Grid.Row="3" Grid.Column="1" x:Name="RegexIgnoreCaseBox" Content="Ignore case"
                               Foreground="{StaticResource Subtext0Brush}" Margin="0,4,0,4" />
                </Grid>

                <TextBlock Margin="0,8,0,0" Foreground="{StaticResource Subtext0Brush}" FontSize="11"
                           TextWrapping="Wrap">
                    Result is rollback-able via Restore History. Snapshot is captured automatically before any change.
                </TextBlock>
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="2" Margin="0,18,0,0">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="Cancel" Click="OnCancel" Margin="0,0,10,0" IsCancel="True" />
                <Button Content="Run" Click="OnRun"
                        Style="{StaticResource AccentButton}"
                        IsDefault="True" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
