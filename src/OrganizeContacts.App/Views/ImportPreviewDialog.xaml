<Window x:Class="OrganizeContacts.App.Views.ImportPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import preview"
        Height="540" Width="820"
        MinHeight="420" MinWidth="700"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="16" FontWeight="SemiBold"
                   Foreground="{StaticResource TextBrush}"
                   AutomationProperties.Name="Import preview heading">
            <Run Text="Preview — " />
            <Run x:Name="FileNameRun" Text="" Foreground="{StaticResource Subtext0Brush}" />
        </TextBlock>

        <TextBlock Grid.Row="1" Margin="0,8,0,12"
                   x:Name="SummaryText"
                   Foreground="{StaticResource Subtext0Brush}" />

        <Border Grid.Row="2"
                Background="{StaticResource MantleBrush}"
                BorderBrush="{StaticResource Surface0Brush}"
                BorderThickness="1" CornerRadius="6">
            <DataGrid x:Name="Grid"
                      AutoGenerateColumns="False"
                      Background="Transparent"
                      Foreground="{StaticResource TextBrush}"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{StaticResource Surface0Brush}"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      BorderThickness="0"
                      IsReadOnly="True"
                      EnableRowVirtualization="True"
                      AutomationProperties.Name="Preview items">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="120" />
                    <DataGridTextColumn Header="Name"   Binding="{Binding Name}"   Width="260" />
                    <DataGridTextColumn Header="UID"    Binding="{Binding Uid}"    Width="180" />
                    <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*"   />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <DockPanel Grid.Row="3" Margin="0,12,0,0" LastChildFill="False">
            <CheckBox x:Name="SnapshotCheckbox"
                      Content="Capture rollback snapshot before commit"
                      IsChecked="True"
                      Foreground="{StaticResource Subtext0Brush}"
                      VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="Cancel" Click="OnCancel" Margin="0,0,10,0" IsCancel="True"
                        AutomationProperties.Name="Cancel import" />
                <Button Content="Commit import" Click="OnCommit"
                        Style="{StaticResource AccentButton}"
                        IsDefault="True"
                        AutomationProperties.Name="Commit this import" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
