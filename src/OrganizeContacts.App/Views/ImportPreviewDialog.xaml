<Window x:Class="OrganizeContacts.App.Views.ImportPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import preview"
        Background="{DynamicResource BaseBrush}"
        Foreground="{DynamicResource TextBrush}"
        Height="620" Width="1040"
        MinHeight="500" MinWidth="860"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Background="{DynamicResource BaseBrush}" Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}"
                   AutomationProperties.Name="Import preview heading">
            <Run Text="Import preview - " />
            <Run x:Name="FileNameRun" Text="" Foreground="{DynamicResource Subtext0Brush}" />
        </TextBlock>

        <TextBlock Grid.Row="1" Margin="0,8,0,12"
                   x:Name="SummaryText"
                   Foreground="{DynamicResource Subtext0Brush}"
                   TextWrapping="Wrap" />

        <Border Grid.Row="2"
                Background="{DynamicResource MantleBrush}"
                BorderBrush="{DynamicResource Surface0Brush}"
                BorderThickness="1" CornerRadius="8">
            <DataGrid x:Name="Grid"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      BorderThickness="0"
                      IsReadOnly="True"
                      EnableRowVirtualization="True"
                      AutomationProperties.Name="Preview items">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="File"   Binding="{Binding File}"   Width="260" />
                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="90" />
                    <DataGridTextColumn Header="Name"   Binding="{Binding Name}"   Width="300" />
                    <DataGridTextColumn Header="UID"    Binding="{Binding Uid}"    Width="160" />
                    <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <DockPanel Grid.Row="3" Margin="0,12,0,0" LastChildFill="False">
            <CheckBox x:Name="SnapshotCheckbox"
                      Content="Capture rollback snapshot before commit"
                      IsChecked="True"
                      VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="Cancel" Click="OnCancel" Margin="0,0,10,0" IsCancel="True"
                        AutomationProperties.Name="Cancel import" />
                <Button Content="Commit import" Click="OnCommit"
                        Style="{StaticResource AccentButton}"
                        IsDefault="True"
                        AutomationProperties.Name="Commit this import" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
