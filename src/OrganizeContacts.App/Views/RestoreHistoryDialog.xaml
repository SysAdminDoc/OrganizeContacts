<Window x:Class="OrganizeContacts.App.Views.RestoreHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Restore history"
        Height="540" Width="780"
        MinHeight="420" MinWidth="640"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Imports and rollback snapshots"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,8,0"
                    Background="{StaticResource MantleBrush}"
                    BorderBrush="{StaticResource Surface0Brush}"
                    BorderThickness="1" CornerRadius="6">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Imports"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Subtext1Brush}"
                               Margin="10,8,10,4" />
                    <ListBox x:Name="ImportsList" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Display}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Detail}"
                                               Foreground="{StaticResource Subtext0Brush}"
                                               FontSize="11" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Margin="8,0,0,0"
                    Background="{StaticResource MantleBrush}"
                    BorderBrush="{StaticResource Surface0Brush}"
                    BorderThickness="1" CornerRadius="6">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Snapshots"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Subtext1Brush}"
                               Margin="10,8,10,4" />
                    <ListBox x:Name="SnapshotList" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Detail}"
                                               Foreground="{StaticResource Subtext0Brush}"
                                               FontSize="11" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>

        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="Close" Click="OnClose" Margin="0,0,10,0" IsCancel="True" />
                <Button Content="Restore selected snapshot" Click="OnRestore"
                        Style="{StaticResource AccentButton}" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
