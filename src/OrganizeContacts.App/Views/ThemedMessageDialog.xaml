<Window x:Class="OrganizeContacts.App.Views.ThemedMessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Message"
        Background="{DynamicResource BaseBrush}"
        Foreground="{DynamicResource TextBrush}"
        Width="500"
        MinWidth="420"
        MaxWidth="680"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Border Background="{DynamicResource BaseBrush}"
            BorderBrush="{DynamicResource Surface0Brush}"
            BorderThickness="1"
            Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="True">
                <Border x:Name="ToneBorder"
                        DockPanel.Dock="Right"
                        Background="{DynamicResource MantleBrush}"
                        BorderBrush="{DynamicResource Surface1Brush}"
                        BorderThickness="1"
                        CornerRadius="11"
                        Padding="9,4"
                        Margin="14,0,0,0">
                    <TextBlock x:Name="ToneText"
                               Foreground="{DynamicResource Subtext1Brush}"
                               FontSize="11"
                               FontWeight="SemiBold" />
                </Border>
                <TextBlock x:Name="CaptionText"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}"
                           TextWrapping="Wrap" />
            </DockPanel>

            <TextBlock x:Name="MessageText"
                       Grid.Row="1"
                       Margin="0,14,0,20"
                       Foreground="{DynamicResource Subtext1Brush}"
                       FontSize="13"
                       LineHeight="20"
                       TextWrapping="Wrap" />

            <StackPanel x:Name="ButtonPanel"
                        Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right" />
        </Grid>
    </Border>
</Window>
